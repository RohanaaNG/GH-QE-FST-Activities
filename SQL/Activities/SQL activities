--select all rows in emp but show dept name from dept table instead of deptno
--inner join
select emp.ename,dept.dname from scott.emp emp inner join scott.dept dept on emp.deptno=dept.deptno;

--identify the dept that is not assigned any employees
--left join
select emp.ename,dept.dname from scott.dept dept left join scott.emp emp on dept.deptno=emp.deptno;

--retrieve data from scott.emp to print following data
--emp name, dept name,manager name
select emp1.ename,emp1.deptno,emp2.mgr from scott.emp emp1 join scott.emp emp2 on emp1.deptno=emp2.deptno;

--using hr schema, retrieve and print the following data
--employee name,department name,city,country,region
--for all employees working in the 'IT' department

select e.first_name,d.department_name,l.city,c.country_name,r.region_name
from hr.employees e JOIN hr.departments d ON d.department_id=e.department_id
join hr.locations l ON d.location_id = l.location_id
JOIN hr.countries c ON l.country_id=c.country_id
JOIN hr.regions r ON c.region_id = r.region_id
where d.department_name='IT'
